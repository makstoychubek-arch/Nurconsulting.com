{
  "buildCommand": "npm install --include=dev && npm run build",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/dashboard.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/(space|logistics|ab-testing|advertising|seo|marking|wb-clusters)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/dist/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "rewrites": [
    { "source": "/login", "destination": "/login.html" },
    { "source": "/space", "destination": "/dashboard.html" },
    { "source": "/ab-testing", "destination": "/dashboard.html" },
    { "source": "/advertising", "destination": "/dashboard.html" },
    { "source": "/seo", "destination": "/dashboard.html" },
    { "source": "/marking", "destination": "/dashboard.html" },
    { "source": "/logistics", "destination": "/dashboard.html" },
    { "source": "/wb-clusters", "destination": "/dashboard.html" },
    { "source": "/rnp-app", "destination": "/rnp-app/index.html" },
    { "source": "/rnp-app/:path*", "destination": "/rnp-app/:path*" },
    { "source": "/marking-app/:path*", "destination": "/marking-app/:path*" },
    { "source": "/", "destination": "/index.html" }
  ]
}
